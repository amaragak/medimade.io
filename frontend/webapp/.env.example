# Base URL from CDK output `ApiUrl` (HTTP API), e.g. https://xxxx.execute-api.ap-southeast-2.amazonaws.com
# No trailing slash. Used for POST /fish/tts.
NEXT_PUBLIC_MEDIMADE_API_URL=
# Lambda Function URL from CDK output `MedimadeChatUrl` (Claude streaming chat, POST JSON body).
NEXT_PUBLIC_MEDIMADE_CHAT_URL=
# Media CDN for MP3s / background audio preview: CDK `MediaCloudFrontDomain` with https://, no trailing slash.
NEXT_PUBLIC_MEDIMADE_MEDIA_BASE_URL=
