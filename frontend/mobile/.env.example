# Copy to `.env` in this folder (frontend/mobile). Expo loads it on `npx expo start`.
# Use the same URL values as frontend/webapp/.env but with this prefix:
#   NEXT_PUBLIC_MEDIMADE_*  →  EXPO_PUBLIC_MEDIMADE_*

# HTTP API base from CDK `ApiUrl` — no trailing slash.
EXPO_PUBLIC_MEDIMADE_API_URL=

# Claude streaming chat — Lambda Function URL from CDK `MedimadeChatUrl`.
EXPO_PUBLIC_MEDIMADE_CHAT_URL=

# Media CDN (background preview / MP3s) — https:// + MediaCloudFrontDomain, no trailing slash.
EXPO_PUBLIC_MEDIMADE_MEDIA_BASE_URL=
