{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "aws-lambda"]
  },
  "include": ["bin/**/*.ts", "lib/**/*.ts", "lambdas/**/*.ts", "scripts/**/*.ts"]
}
