#!/usr/bin/env bash
# Sync local audio/bg-audio folder into the media S3 bucket.
# Use subfolders nature/, music/, and drums/ under audio/bg-audio so the create UI can list each category.
# Usage (from repo root or anywhere):
#   backend/scripts/sync-bg-audio
#   backend/scripts/sync-bg-audio --profile mm
#   backend/scripts/sync-bg-audio --force-update --profile mm
#
# Requires:
# - aws CLI configured and on PATH
# - The MedimadeBackend stack deployed with a CfnOutput export "MediaBucketName"
# - Background audio normalizer S3 trigger (uploads go to background-audio-raw/ and are normalized into background-audio/)
set -euo pipefail

BACKEND_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REPO_ROOT="$(cd "$BACKEND_ROOT/.." && pwd)"
BG_DIR="$REPO_ROOT/audio/bg-audio"

if ! command -v aws >/dev/null 2>&1; then
  echo "aws CLI is required but not found on PATH." >&2
  exit 1
fi

FORCE_UPDATE="0"
AWS_ARGS=()
for a in "$@"; do
  if [ "$a" = "--force-update" ]; then
    FORCE_UPDATE="1"
  else
    AWS_ARGS+=("$a")
  fi
done

if [ ! -d "$BG_DIR" ]; then
  echo "Expected audio/bg-audio directory at: $BG_DIR" >&2
  exit 1
fi

echo "Resolving media bucket from CloudFormation export 'MediaBucketName'..."
MEDIA_BUCKET_NAME="$(
  aws cloudformation list-exports "${AWS_ARGS[@]}" \
    --query "Exports[?Name=='MediaBucketName'].Value | [0]" \
    --output text
)"

if [ -z "$MEDIA_BUCKET_NAME" ] || [ "$MEDIA_BUCKET_NAME" = "None" ]; then
  echo "Could not resolve MediaBucketName CloudFormation export. Has the stack been deployed?" >&2
  exit 1
fi

SRC="$BG_DIR/"
DEST_RAW="s3://$MEDIA_BUCKET_NAME/background-audio-raw/"
DEST_NORM="s3://$MEDIA_BUCKET_NAME/background-audio/"

if [ "$FORCE_UPDATE" = "1" ]; then
  echo "Force update: COMPLETE mirror of local -> S3."
  echo "  1) Remove all objects under background-audio-raw/ and background-audio/"
  echo "  2) Upload every .mp3 / .wav from $SRC (each Put triggers the normalizer Lambda)"
  echo ""
  echo "Clearing raw prefix: $DEST_RAW"
  aws s3 rm "$DEST_RAW" --recursive "${AWS_ARGS[@]}" || true
  echo "Clearing normalized prefix: $DEST_NORM"
  aws s3 rm "$DEST_NORM" --recursive "${AWS_ARGS[@]}" || true

  count=0
  while IFS= read -r -d '' f; do
    rel="${f#"$BG_DIR"/}"
    rel="${rel#/}"
    echo "upload -> background-audio-raw/$rel"
    aws s3 cp "$f" "s3://$MEDIA_BUCKET_NAME/background-audio-raw/$rel" "${AWS_ARGS[@]}"
    count=$((count + 1))
  done < <(find "$BG_DIR" -type f \( -iname '*.mp3' -o -iname '*.wav' \) -print0)

  echo ""
  echo "Uploaded $count file(s) to raw. Normalized copies will appear under background-audio/ as the Lambda runs."
  echo "If background-audio/ stays empty, check CloudWatch logs for the bg-audio-normalize function and S3 event notifications on this bucket."
else
  echo "Syncing $SRC -> $DEST_RAW"
  aws s3 sync "$SRC" "$DEST_RAW" \
    --exclude "*" \
    --include "*.mp3" \
    --include "*.wav" \
    "${AWS_ARGS[@]}"
fi

echo "Done."
