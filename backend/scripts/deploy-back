#!/usr/bin/env bash
# Deploy CDK stack and sync stack outputs into:
#   frontend/webapp/.env   — NEXT_PUBLIC_MEDIMADE_* (Next.js)
#   frontend/mobile/.env   — EXPO_PUBLIC_MEDIMADE_* (Expo)
# Usage (from anywhere):
#   backend/scripts/deploy-back
#   backend/scripts/deploy-back --profile mm
#   backend/scripts/deploy-back MedimadeBackend --require-approval never --profile mm
set -euo pipefail

BACKEND_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REPO_ROOT="$(cd "$BACKEND_ROOT/.." && pwd)"
WEBAPP_ENV="$REPO_ROOT/frontend/webapp/.env"
MOBILE_ENV="$REPO_ROOT/frontend/mobile/.env"
OUTPUTS="$(mktemp)"
cleanup() { rm -f "$OUTPUTS"; }
trap cleanup EXIT

cd "$BACKEND_ROOT"

npx cdk deploy "$@" --outputs-file "$OUTPUTS"

node "$BACKEND_ROOT/scripts/write-webapp-env-from-outputs.mjs" "$OUTPUTS" "$WEBAPP_ENV" "$MOBILE_ENV"
