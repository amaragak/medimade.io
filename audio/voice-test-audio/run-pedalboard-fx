#!/usr/bin/env bash
# One-command runner: creates audio/voice-test-audio/.venv on first use (gitignored), then runs the script.
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
VENV="$DIR/.venv"
PY="$VENV/bin/python"
if [ ! -x "$PY" ]; then
  echo "First run: creating venv in audio/voice-test-audio/.venv …" >&2
  python3 -m venv "$VENV"
  "$VENV/bin/pip" install -q --upgrade pip
  "$VENV/bin/pip" install -q "pedalboard==0.9.16" "numpy"
fi
exec "$PY" "$DIR/pedalboard_local_fx.py" "$@"
